# chitta v0.1.0 — example configuration.
# Place at ~/.chitta/.env (loaded automatically) or override with env vars.
# All values have sensible defaults — zero config required for local dev.

# Postgres connection string. Requires the `vector` extension
# (https://github.com/pgvector/pgvector). Any libpq-compatible URL works.
# DATABASE_URL=postgresql://josh:ogham@localhost/chitta_rs

# Data directory. Default: ~/.chitta/
# CHITTA_HOME=~/.chitta

# Directory containing `bge_m3_model.onnx` (+ its `.onnx_data` sidecar) and
# `tokenizer.json`. Defaults to ~/.chitta/models/bge-m3-onnx if unset.
# CHITTA_MODEL_PATH=~/.chitta/models/bge-m3-onnx

# tracing_subscriber env filter. Common values: `trace`, `debug`, `info`
# (default), `warn`, `error`. Per-crate filters also work, e.g.
# `info,sqlx=warn`.
# CHITTA_LOG_LEVEL=info

# Connection pool tuning. Defaults are sensible for single-user stdio;
# increase max_connections before adding HTTP transport.
# CHITTA_DB_MAX_CONNECTIONS=8
# CHITTA_DB_ACQUIRE_TIMEOUT=5
# CHITTA_DB_IDLE_TIMEOUT=600

# Path to `libonnxruntime.so`. Required by the `ort` crate's dynamic-load
# mode. If your system package manager installs it to a standard location
# (e.g. /usr/lib), you can leave this unset. Otherwise point at the shared
# library directly — the Python `onnxruntime` wheel ships one you can reuse.
# ORT_DYLIB_PATH=/usr/lib/libonnxruntime.so
